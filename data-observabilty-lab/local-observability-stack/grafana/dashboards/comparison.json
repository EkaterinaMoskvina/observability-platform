    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU — Prometheus vs ClickHouse (%)",
      "description": "Prometheus: rate(process_cpu_seconds_total[5m]) * 100. ClickHouse: суммарное CPU время (user + system), нормализованное в %.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Prometheus CPU %" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E05F27", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "ClickHouse CPU %" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#1F78C1", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(process_cpu_seconds_total{job=\"prometheus\"}[5m]) * 100",
          "legendFormat": "Prometheus CPU %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(rate(ClickHouseAsyncMetrics_OSUserTimeCPU{job=\"clickhouse\"}[5m]) + rate(ClickHouseAsyncMetrics_OSSystemTimeCPU{job=\"clickhouse\"}[5m])) * 100",
          "legendFormat": "ClickHouse CPU %",
          "refId": "B"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Скорость записи (Write Throughput)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Write Throughput — сэмплов/строк в секунду",
      "description": "Оба хранилища получают одинаковый поток от OTel Collector. Prometheus считает сэмплы (samples), ClickHouse — вставленные строки (InsertedRows). Прямое сравнение скорости приёма данных.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Prometheus samples/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E05F27", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "ClickHouse rows/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#1F78C1", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(prometheus_tsdb_head_samples_appended_total{job=\"prometheus\"}[5m])",
          "legendFormat": "Prometheus samples/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ClickHouseProfileEvents_InsertedRows{job=\"clickhouse\"}[5m])",
          "legendFormat": "ClickHouse rows/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Байт записано в секунду",
      "description": "Prometheus: байты, записанные в WAL. ClickHouse: байты вставленных данных (до компрессии).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
