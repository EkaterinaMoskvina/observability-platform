      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT now() as time, value FROM system.metrics WHERE metric = 'BackgroundMergesAndMutationsPoolTask' LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 3 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT now() as time, value FROM system.asynchronous_metrics WHERE metric = 'Uptime' LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Версия ClickHouse",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 3 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT now() as time, version() as version",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "OTel Данные — Метрики рабочей станции в ClickHouse",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Utilization (из ClickHouse)",
      "description": "system.cpu.utilization из таблицы otel_metrics_gauge. Данные записаны OTel Collector через clickhouse exporter.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfInterval(TimeUnix, INTERVAL 30 SECOND) as time, avg(Value) as cpu_avg, Attributes['cpu'] as cpu_id FROM otel_metrics_gauge WHERE MetricName = 'system.cpu.utilization' AND Attributes['state'] = 'user' AND $__timeFilter(TimeUnix) GROUP BY time, cpu_id ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory Utilization (из ClickHouse)",
      "description": "system.memory.utilization из таблицы otel_metrics_gauge.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfInterval(TimeUnix, INTERVAL 30 SECOND) as time, avg(Value) as value, Attributes['state'] as state FROM otel_metrics_gauge WHERE MetricName = 'system.memory.utilization' AND $__timeFilter(TimeUnix) GROUP BY time, state ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Disk I/O (из ClickHouse)",
      "description": "system.disk.io из таблицы otel_metrics_sum — байты read/write с диска.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfInterval(TimeUnix, INTERVAL 30 SECOND) as time, sum(Value) as io_bytes, Attributes['direction'] as direction, Attributes['device'] as device FROM otel_metrics_sum WHERE MetricName = 'system.disk.io' AND $__timeFilter(TimeUnix) GROUP BY time, direction, device ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Network I/O (из ClickHouse)",
      "description": "system.network.io из таблицы otel_metrics_sum.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfInterval(TimeUnix, INTERVAL 30 SECOND) as time, sum(Value) as net_bytes, Attributes['direction'] as direction, Attributes['interface'] as iface FROM otel_metrics_sum WHERE MetricName = 'system.network.io' AND $__timeFilter(TimeUnix) GROUP BY time, direction, iface ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Хранилище OTel в ClickHouse",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "table",
      "title": "Таблицы OTel — размер и строки",
      "description": "Размер OTel метрик таблиц в базе данных otel: количество строк, сжатые и несжатые байты, коэффициент сжатия.",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 25 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "compressed_bytes" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "uncompressed_bytes" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "rows", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT table, formatReadableQuantity(sum(rows)) as rows, sum(bytes_on_disk) as compressed_bytes, sum(data_uncompressed_bytes) as uncompressed_bytes, round(sum(data_uncompressed_bytes) / nullIf(sum(bytes_on_disk), 0), 2) as compression_ratio FROM system.parts WHERE database = 'otel' AND active = 1 GROUP BY table ORDER BY sum(bytes_on_disk) DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Суммарный размер OTel таблиц",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT now() as time, sum(bytes_on_disk) as compressed, sum(data_uncompressed_bytes) as uncompressed FROM system.parts WHERE database = 'otel' AND active = 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "type": "stat",
      "title": "Средний коэффициент сжатия",
      "description": "Отношение несжатых байт к сжатым. Значение 5 означает: данные занимают в 5 раз меньше места на диске.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 29 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 4 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT now() as time, round(sum(data_uncompressed_bytes) / nullIf(sum(bytes_on_disk), 0), 2) as ratio FROM system.parts WHERE database = 'otel' AND active = 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Query Log — Задержка запросов (Query Latency)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Query Latency P50 / P95 / P99 (из system.query_log)",
      "description": "Задержка выполнения запросов ClickHouse из system.query_log. Группировка по 1 минуте. type=2 — успешно завершённые запросы.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50_sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95_sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p99_sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfInterval(event_time, INTERVAL 1 MINUTE) as time, quantile(0.50)(query_duration_ms) / 1000 as p50_sec, quantile(0.95)(query_duration_ms) / 1000 as p95_sec, quantile(0.99)(query_duration_ms) / 1000 as p99_sec FROM system.query_log WHERE type = 2 AND $__timeFilter(event_time) GROUP BY time ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 42,
      "type": "table",
      "title": "Топ-10 медленных запросов (за выбранный период)",
      "description": "Самые долгие SELECT запросы из system.query_log. Полезно для оптимизации Grafana PromQL → SQL миграции.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 42 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [
              { "id": "unit", "value": "ms" },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 100 },
                    { "color": "red", "value": 1000 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "read_bytes" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "duration_ms", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT event_time, query_duration_ms as duration_ms, read_bytes, read_rows, left(query, 120) as query_preview, user FROM system.query_log WHERE type = 2 AND $__timeFilter(event_time) AND query NOT LIKE '%system.%' ORDER BY query_duration_ms DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "Метрики именованных метрик в ClickHouse",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "table",
      "title": "Все типы метрик в ClickHouse (MetricName, count)",
      "description": "Какие метрики хранятся в ClickHouse и сколько их. Позволяет убедиться, что все метрики агента доходят до ClickHouse.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 51 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } }
      },
      "options": { "sortBy": [{ "displayName": "cnt", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT MetricName, count() as cnt, min(TimeUnix) as first_seen, max(TimeUnix) as last_seen FROM otel_metrics_gauge WHERE $__timeFilter(TimeUnix) GROUP BY MetricName UNION ALL SELECT MetricName, count() as cnt, min(TimeUnix) as first_seen, max(TimeUnix) as last_seen FROM otel_metrics_sum WHERE $__timeFilter(TimeUnix) GROUP BY MetricName ORDER BY cnt DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Скорость вставки строк в ClickHouse (из query_log)",
      "description": "Количество строк, вставленных в секунду, из system.query_log. Показывает throughput OTel Collector → ClickHouse pipeline.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 51 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfInterval(event_time, INTERVAL 1 MINUTE) as time, sum(written_rows) as rows_written, sum(written_bytes) as bytes_written FROM system.query_log WHERE type = 2 AND query_kind = 'Insert' AND $__timeFilter(event_time) GROUP BY time ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ],
