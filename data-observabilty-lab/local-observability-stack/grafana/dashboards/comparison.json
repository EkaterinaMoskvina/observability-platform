    {
      "id": 42,
      "type": "timeseries",
      "title": "Задержка записи (Write Latency)",
      "description": "Prometheus: длительность remote write запросов входящих (через remote write receiver). ClickHouse: длительность INSERT запросов из system.query_log, агрегированная через ProfileEvents.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
