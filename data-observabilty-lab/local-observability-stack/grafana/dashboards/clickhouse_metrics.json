{
  "id": null,
  "uid": "clickhouse-metrics",
  "title": "ClickHouse Metrics",
  "description": "Метрики, хранящиеся в ClickHouse (OTel данные от агента) + системные таблицы ClickHouse. Использует ClickHouse datasource (SQL запросы).",
  "tags": ["clickhouse", "otel", "metrics"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## ClickHouse Metrics — OTel данные + System Tables\n\nДанные из таблиц `otel.otel_metrics_gauge` / `otel_metrics_sum` (метрики рабочей станции) и `system.*` (внутреннее состояние ClickHouse)."
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Состояние ClickHouse (System Metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Активных запросов",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 3 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT now() as time, value FROM system.metrics WHERE metric = 'Query' LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Соединений TCP",
