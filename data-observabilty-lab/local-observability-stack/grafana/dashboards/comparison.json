          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ClickHouseProfileEvents_InsertQuery{job=\"clickhouse\"}[5m])",
          "legendFormat": "ClickHouse INSERT queries/s",
          "refId": "B"
        }
      ]
    },
