    },
    {
      "id": 5,
      "type": "stat",
      "title": "Background Merges",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 3 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
