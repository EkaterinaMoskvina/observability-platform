<clickhouse>
    <!--
        Включает встроенный Prometheus endpoint ClickHouse.
        Доступен на http://clickhouse:9363/metrics
        Prometheus scrapes его в job_name='clickhouse'

        Экспортируемые метрики:
          ClickHouseMetrics_*          — текущее состояние (запросы, соединения, память)
          ClickHouseAsyncMetrics_*     — async метрики (RAM RSS, CPU, storage)
          ClickHouseProfileEvents_*    — счётчики событий (InsertedRows, InsertedBytes, ...)
          ClickHouseStatusInfo_*       — статус (uptime, версия)
    -->
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <errors_in_output_disabled>false</errors_in_output_disabled>
    </prometheus>
</clickhouse>
